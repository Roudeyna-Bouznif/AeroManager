<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projet_java_vols.Gestion_des_vols.Controller.GestionEscalesController"
            prefWidth="1200"
            prefHeight="700"
            stylesheets="@style.css">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="header-container">

                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 15 0 0;">
                    <Label text="✈ " styleClass="logo-icon"/>
                    <Label text="AeroManager" styleClass="logo-text"/>
                </HBox>

                <Separator orientation="VERTICAL" styleClass="separator-vertical">
                    <HBox.margin>
                        <Insets left="10" right="15"/>
                    </HBox.margin>
                </Separator>

                <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Button fx:id="btnMenuEmployes" text="👥 Employés"
                            onAction="#allerEmploye"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>

                    <Button fx:id="btnMenuAeroports" text="🏢 Aéroports"
                            onAction="#allerAeroports"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>

                    <Button fx:id="btnMenuVols" text="✈ Vols"
                            onAction="#allerVols"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>

                    <Button fx:id="btnMenuEscales" text="🛬 Escales"
                            onAction="#allerEscales"
                            styleClass="menu-btn-active"/>

                    <Button fx:id="btnMenuReservations" text="🎫 Réservations"
                            onAction="#allerReservations"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                    <Button fx:id="btnMenuStats" text="📈 Statistiques"
                            onAction="#allerStats"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">


                    <Separator orientation="VERTICAL" styleClass="separator-vertical">
                        <HBox.margin>
                            <Insets left="5" right="5"/>
                        </HBox.margin>
                    </Separator>

                    <Button text="👤 Déconnexion"
                            onAction="#deconnexion"
                            styleClass="admin-badge"
                            style="-fx-cursor: hand; -fx-border-color: transparent; -fx-background-color: #eff6ff; -fx-text-fill: #1e40af;"/>

                </HBox>
            </HBox>

            <HBox alignment="CENTER" spacing="8" styleClass="sub-header">
                <Label text="🛬" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                <Label text="Gestion des Escales" styleClass="sub-header-title"/>
                <Label text="•" style="-fx-text-fill: #93c5fd; -fx-font-size: 14px;"/>
                <Label text="Gestion des arrêts intermédiaires des vols"
                       style="-fx-text-fill: #bfdbfe; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
    <VBox fx:id="vboxFormulaire" spacing="8" styleClass="content-area">

        <VBox fx:id="containerSaisie" spacing="6" styleClass="card-container">
            <Label text="📝 Informations de l'Escale" styleClass="section-title"/>
            <Separator styleClass="blue-separator"/>

            <GridPane hgap="16" vgap="12" styleClass="form-grid-container">
                <columnConstraints>
                <ColumnConstraints minWidth="80" prefWidth="120"/>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
                <ColumnConstraints minWidth="80" prefWidth="120"/>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
            </columnConstraints>

            <Label text="N° Vol:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
            <ComboBox fx:id="cmbVol" promptText="Sélectionnez le vol"
                      styleClass="combo-box-custom"
                      GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>

            <Label text="Ordre:" GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="form-label"/>
            <Spinner fx:id="spinOrdre" min="1" max="10" initialValue="1" editable="true"
                     styleClass="spinner-custom"
                     GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <Label text="Départ:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
            <ComboBox fx:id="cmbAeroportDepart" promptText="Aéroport départ"
                      styleClass="combo-box-custom"
                      GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Arrivée:" GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="form-label"/>
            <ComboBox fx:id="cmbAeroportArrivee" promptText="Aéroport arrivée"
                      styleClass="combo-box-custom"
                      GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Label text="Date Départ:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
            <DatePicker fx:id="dpDateDepart" promptText="JJ/MM/AAAA"
                        styleClass="date-picker-custom"
                        GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Date Arrivée:" GridPane.columnIndex="2" GridPane.rowIndex="2" styleClass="form-label"/>
            <DatePicker fx:id="dpDateArrivee" promptText="JJ/MM/AAAA"
                        styleClass="date-picker-custom"
                        GridPane.columnIndex="3" GridPane.rowIndex="2"/>

            <Label text="Heure Départ:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
            <TextField fx:id="txtHeureDepart" promptText="HH:MM"
                       styleClass="text-field-custom"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Heure Arrivée:" GridPane.columnIndex="2" GridPane.rowIndex="3" styleClass="form-label"/>
            <TextField fx:id="txtHeureArrivee" promptText="HH:MM"
                       styleClass="text-field-custom"
                       GridPane.columnIndex="3" GridPane.rowIndex="3"/>
        </GridPane>

        <HBox alignment="CENTER" spacing="8" styleClass="info-box-success">
            <Label text="⏱️" style="-fx-font-size: 16px;"/>
            <Label text="Durée calculée:" styleClass="info-label"/>
            <Label fx:id="lblDuree" text="-- min" styleClass="info-value"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER">
            <Button fx:id="btnAjouter" text="➕ Ajouter"
                    onAction="#ajouterEscale"
                    styleClass="btn-primary"/>
            <Button fx:id="btnAnnuler" text="❌ Annuler"
                    onAction="#annulerAction"
                    styleClass="btn-secondary"/>
        </HBox>
    </VBox>

    <VBox spacing="6" styleClass="card-container" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="📋 Liste des Escales" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNombreEscales" text="Total: 0" styleClass="counter-badge"/>
        </HBox>
        <Separator styleClass="blue-separator"/>

        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="🔍" style="-fx-font-size: 14px;"/>
            <TextField fx:id="txtRecherche"
                       promptText="Rechercher escale..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <TableView fx:id="tableEscales" styleClass="table-view-custom" VBox.vgrow="ALWAYS">
            <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNumVol" text="N° Vol" prefWidth="100" styleClass="column-header-center"/>
            <TableColumn fx:id="colOrdre" text="Ordre" prefWidth="70" styleClass="column-header-center"/>
            <TableColumn fx:id="colAeroportDepart" text="Aéroport Départ" prefWidth="150" styleClass="column-header-center"/>
            <TableColumn fx:id="colAeroportArrivee" text="Aéroport Arrivée" prefWidth="150" styleClass="column-header-center"/>
            <TableColumn fx:id="colDateDepart" text="Date Départ" prefWidth="100" styleClass="column-header-center"/>
            <TableColumn fx:id="colHeureDepart" text="Heure Départ" prefWidth="90" styleClass="column-header-center"/>
            <TableColumn fx:id="colDateArrivee" text="Date Arrivée" prefWidth="100" styleClass="column-header-center"/>
            <TableColumn fx:id="colHeureArrivee" text="Heure Arrivée" prefWidth="90" styleClass="column-header-center"/>
        </columns>
        <placeholder>
            <VBox spacing="1" alignment="CENTER">
                <Label text="🛬" style="-fx-font-size: 38px; -fx-text-fill: #93c5fd;"/>
                <Label text="Aucune escale enregistrée"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
            </VBox>
        </placeholder>
    </TableView>
</VBox>
        </VBox>
        </center>

<bottom>
<HBox alignment="CENTER" spacing="10" styleClass="footer-bar">
    <Button fx:id="btnSupprimer" text="🗑 Supprimer"
            onAction="#supprimerEscale"
            styleClass="btn-danger"/>
    <Button fx:id="btnModifier" text="✏ Modifier"
            onAction="#modifierEscale"
            styleClass="btn-modify"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="Quitter"
            onAction="#quitter"
            styleClass="btn-secondary"/>
</HBox>
</bottom>
        </BorderPane>
