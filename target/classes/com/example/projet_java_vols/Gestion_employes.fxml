<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projet_java_vols.Gestion_des_utilisateurs.Controller.GestionEmployesController"
            prefWidth="1200" prefHeight="700"
            stylesheets="@style.css">

    <top>
        <VBox>
            <!-- Header Principal -->
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="header-container">

                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 15 0 0;">
                    <Label text="✈ " styleClass="logo-icon"/>
                    <Label text="AeroManager" styleClass="logo-text"/>
                </HBox>

                <Separator orientation="VERTICAL" styleClass="separator-vertical">
                    <HBox.margin>
                        <Insets left="10" right="15"/>
                    </HBox.margin>
                </Separator>

                <!-- Menu Navigation -->
                <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Button text="👥 Employés"
                            styleClass="menu-btn-active"/>

                    <Button text="🏢 Aéroports" onAction="#allerAeroports"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>

                    <Button text="✈ Vols" onAction="#allerVols"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>

                    <Button text="🛬 Escales" onAction="#allerEscales"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>

                    <Button text="🎫 Réservations" onAction="#allerReservations"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>
                    <Button  text="📈 Statistiques"
                            onAction="#allerStats"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                </HBox>

                <!-- Outils & Admin -->
                <HBox spacing="10" alignment="CENTER_RIGHT">

                    <Separator orientation="VERTICAL" styleClass="separator-vertical">
                        <HBox.margin>
                            <Insets left="5" right="5"/>
                        </HBox.margin>
                    </Separator>

                    <Button text="👤 Déconnexion"
                            onAction="#deconnexion"
                            styleClass="admin-badge"
                            style="-fx-cursor: hand; -fx-border-color: transparent; -fx-background-color: #eff6ff; -fx-text-fill: #1e40af;"/>

                </HBox>
            </HBox>

            <!-- Sous-titre Gestion Employés -->
            <HBox alignment="CENTER" spacing="8" styleClass="sub-header">
                <Label text="👥" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                <Label text="Gestion des Employés" styleClass="sub-header-title"/>
                <Label text="•" style="-fx-text-fill: #93c5fd;"/>
                <Label fx:id="lblAdminInfo"
                       text="Administrateur: -"
                       style="-fx-text-fill: #bfdbfe; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
    <VBox spacing="8" styleClass="content-area">

        <!-- Formulaire -->
        <VBox spacing="10" styleClass="card-container">
            <Label text="📝 Informations de l'employé" styleClass="section-title"/>
            <Separator styleClass="blue-separator"/>

            <GridPane hgap="12" vgap="10" styleClass="form-grid-container">
                <columnConstraints>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
                <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
                <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
            <ComboBox fx:id="cmbTypeEmploye"
                      promptText="Agent de Vol / Agent d'Enregistrement"
                      GridPane.columnIndex="1" GridPane.rowIndex="0"
                      styleClass="combo-box-custom"/>

            <Label text="Nom:" GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="form-label"/>
            <TextField fx:id="txtNom" GridPane.columnIndex="3" GridPane.rowIndex="0"
                       promptText="Nom"
                       styleClass="text-field-custom"/>

            <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
            <TextField fx:id="txtPrenom" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       promptText="Prénom"
                       styleClass="text-field-custom"/>

            <Label text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="form-label"/>
            <TextField fx:id="txtEmail" GridPane.columnIndex="3" GridPane.rowIndex="1"
                       promptText="email@example.com"
                       styleClass="text-field-custom"/>

            <Label text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
            <TextField fx:id="txtTelephone" GridPane.columnIndex="1" GridPane.rowIndex="2"
                       promptText="0612345678"
                       styleClass="text-field-custom"/>

            <Label text="Mot de passe:" GridPane.columnIndex="2" GridPane.rowIndex="2" styleClass="form-label"/>
            <PasswordField fx:id="txtMotDePasse" GridPane.columnIndex="3" GridPane.rowIndex="2"
                           promptText="Mot de passe"
                           styleClass="password-field-custom"/>

            <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
            <ComboBox fx:id="cmbStatut"
                      promptText="Actif / Inactif"
                      GridPane.columnIndex="1" GridPane.rowIndex="3"
                      styleClass="combo-box-custom"/>
        </GridPane>

        <!-- Sous-Formulaire : Agent de Vol -->
        <VBox fx:id="vboxAgentVol" spacing="8" styleClass="sub-form-box" managed="false" visible="false">
            <Label text="Agent de Vol" styleClass="section-title"/>

            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
                <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
                <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Code compagnie:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txtCodeCompagnie" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Nom compagnie:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="txtNomCompagnie" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <Label text="Pays d'origine:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtPaysOrigine" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Flotte:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="txtFlotte" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Sous-Formulaire : Agent d'Enregistrement -->
    <VBox fx:id="vboxAgentEnreg" spacing="8" styleClass="sub-form-box" managed="false" visible="false">
        <Label text="Agent d'Enregistrement" styleClass="section-title"/>

        <GridPane hgap="10" vgap="8">
            <columnConstraints>
            <ColumnConstraints minWidth="140" prefWidth="150"/>
            <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
            <ColumnConstraints minWidth="140" prefWidth="150"/>
            <ColumnConstraints minWidth="180" hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Bureau:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtBureau" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Comptoir:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="txtComptoir" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
    </GridPane>
</VBox>

<HBox spacing="8" alignment="CENTER">
<Button text="➕ Ajouter"
        onAction="#ajouterEmploye"
        styleClass="btn-primary"/>
<Button text="❌ Annuler"
        onAction="#effacerFormulaire"
        styleClass="btn-secondary"/>
</HBox>
        </VBox>


<VBox spacing="6" VBox.vgrow="ALWAYS" styleClass="card-container">
<HBox alignment="CENTER_LEFT" spacing="8">
    <Label text="📋 Liste des employés" styleClass="section-title"/>
    <Region HBox.hgrow="ALWAYS"/>
</HBox>

<Separator/>

<TableView fx:id="tableEmployes" styleClass="table-view-custom" VBox.vgrow="ALWAYS">
    <columns>
    <TableColumn fx:id="colIdEmploye" text="ID" prefWidth="60"/>
    <TableColumn fx:id="colNom" text="Nom" prefWidth="60"/>
    <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="60"/>
    <TableColumn fx:id="colEmail" text="Email" prefWidth="80"/>
    <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
    <TableColumn fx:id="colType" text="Type" prefWidth="140"/>
    <TableColumn fx:id="colActif" text="Actif" prefWidth="60"/>
    <TableColumn fx:id="colCodeCompagnie" text="Code Cie" prefWidth="80"/>
    <TableColumn fx:id="colNomCompagnie" text="Nom Cie" prefWidth="120"/>
    <TableColumn fx:id="colPaysOrigine" text="Pays" prefWidth="100"/>
    <TableColumn fx:id="colFlotte" text="Flotte" prefWidth="70"/>
    <TableColumn fx:id="colBureau" text="Bureau" prefWidth="120"/>
    <TableColumn fx:id="colComptoir" text="Comptoir" prefWidth="80"/>
</columns>
</TableView>
        </VBox>
        </VBox>
        </center>

<bottom>
<HBox alignment="CENTER" spacing="10" styleClass="footer-bar">
    <Button fx:id="btnSupprimer"
            text="🗑 Supprimer"
            onAction="#supprimerEmployeSelection"
            styleClass="btn-danger"/>

    <Button fx:id="btnModifier"
            text="✏ Modifier"
            onAction="#modifierEmployeSelection"
            styleClass="btn-modify"/>

    <Region HBox.hgrow="ALWAYS"/>

    <Button text="Quitter"
            onAction="#quitter"
            styleClass="btn-secondary"/>
</HBox>
</bottom>

        </BorderPane>
