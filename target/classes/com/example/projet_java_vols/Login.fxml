<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projet_java_vols.Gestion_des_utilisateurs.Controller.LoginController"
            prefWidth="800"
            prefHeight="650"
            stylesheets="@style.css"
            style="-fx-background-color: #f0f8ff;">

    <top>
        <VBox styleClass="login-header">
            <HBox alignment="CENTER" spacing="15">
                <Label text="✈ " styleClass="login-title-icon"/>
                <Label text="Système de Gestion de Vols" styleClass="login-title-text"/>
            </HBox>
            <Label text="Connexion à votre espace" styleClass="login-subtitle" alignment="CENTER">
                <VBox.margin>
                    <Insets top="5"/>
                </VBox.margin>
            </Label>
        </VBox>
    </top>

    <center>
    <VBox spacing="20" style="-fx-padding: 25;">

        <VBox spacing="15" styleClass="login-card">

            <VBox alignment="CENTER" spacing="5">
                <Label text="Bienvenue !" styleClass="login-welcome-text"/>
                <Label text="Veuillez vous connecter pour continuer" styleClass="login-instruction-text"/>
            </VBox>

            <Separator styleClass="blue-separator"/>

            <VBox spacing="10">
                <Label text="👤 Nom d'utilisateur" styleClass="login-field-label"/>
                <TextField fx:id="txtUsername"
                           promptText="Entrez votre nom d'utilisateur"
                           styleClass="login-field"/>
            </VBox>

            <VBox spacing="10">
                <Label text="🔒 Mot de passe" styleClass="login-field-label"/>
                <PasswordField fx:id="txtPassword"
                               promptText="Entrez votre mot de passe"
                               styleClass="login-field"/>
            </VBox>

            <HBox fx:id="errorBox"
                  visible="false"
                  managed="false"
                  alignment="CENTER"
                  spacing="10"
                  styleClass="error-box">
                <Label text="⚠ " style="-fx-font-size: 18px;"/>
                <Label fx:id="lblError"
                       text="Nom d'utilisateur ou mot de passe incorrect"
                       styleClass="error-text"
                       wrapText="true"
                       HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <Button fx:id="btnLogin"
                        text="🔐 Se Connecter"
                        onAction="#handleLogin"
                        defaultButton="true"
                        styleClass="btn-login"/>
            </HBox>
        </VBox>

    </VBox>
</center>

<bottom>
</bottom>

<StackPane fx:id="loadingOverlay"
           visible="false"
           managed="false"
           styleClass="loading-overlay">
<VBox alignment="CENTER" spacing="15">
    <ProgressIndicator style="-fx-progress-color: #2563eb;"/>
    <Label text="Connexion en cours..." styleClass="loading-text"/>
</VBox>
</StackPane>

        </BorderPane>
