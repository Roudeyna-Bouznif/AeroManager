<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projet_java_vols.Gestion_des_vols.Controller.GestionVolsController"
            prefWidth="1200"
            prefHeight="700"
            stylesheets="@style.css">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="header-container">

                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 15 0 0;">
                    <Label text="✈ " styleClass="logo-icon"/>
                    <Label text="AeroManager" styleClass="logo-text"/>
                </HBox>

                <Separator orientation="VERTICAL" styleClass="separator-vertical">
                    <HBox.margin>
                        <Insets left="10" right="15"/>
                    </HBox.margin>
                </Separator>

                <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Button fx:id="btnMenuEmployes" text="👥 Employés"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            onAction="#allerEmploye"/>

                    <Button fx:id="btnMenuAeroports" text="🏢 Aéroports" onAction="#allerAeroports"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>

                    <Button fx:id="btnMenuVols" text="✈ Vols" onAction="#allerVols"
                            styleClass="menu-btn-active"/>

                    <Button fx:id="btnMenuEscales" text="🛬 Escales" onAction="#allerEscales"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>

                    <Button fx:id="btnMenuReservations" text="🎫 Réservations" onAction="#allerReservations"
                            styleClass="menu-btn"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"/>

                    <Button fx:id="btnMenuStats" text="📈 Statistiques"
                            onAction="#allerStats"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">


                    <Separator orientation="VERTICAL" styleClass="separator-vertical">
                        <HBox.margin>
                            <Insets left="5" right="5"/>
                        </HBox.margin>
                    </Separator>

                    <Button text="👤 Déconnexion"
                            onAction="#deconnexion"
                            styleClass="admin-badge"
                            style="-fx-cursor: hand; -fx-border-color: transparent; -fx-background-color: #eff6ff; -fx-text-fill: #1e40af;"/>

                </HBox>
            </HBox>

            <HBox alignment="CENTER" spacing="8" styleClass="sub-header">
                <Label text="✈" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                <Label text="Gestion des Vols" styleClass="sub-header-title"/>
                <Label text="•" style="-fx-text-fill: #93c5fd; -fx-font-size: 14px;"/>
                <Label text="Système de gestion des vols internationaux et nationaux"
                       style="-fx-text-fill: #bfdbfe; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
    <VBox fx:id="vboxFormulaire" spacing="8" styleClass="content-area">

        <VBox spacing="6" fx:id="containerSaisie" styleClass="card-container">
            <Label text="📝 Informations du Vol" styleClass="section-title"/>
            <Separator styleClass="blue-separator"/>

            <GridPane hgap="18" vgap="5" maxWidth="Infinity">
                <columnConstraints>
                <ColumnConstraints percentWidth="33"/>
                <ColumnConstraints percentWidth="33"/>
                <ColumnConstraints percentWidth="33"/>
            </columnConstraints>

            <Label text="Type de Vol:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <HBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <RadioButton fx:id="rbInternational" text="International" selected="true"
                             styleClass="radio-custom" onAction="#onTypeVolChanged"/>
                <RadioButton fx:id="rbNational" text="National"
                             styleClass="radio-custom" onAction="#onTypeVolChanged"/>
            </HBox>

            <Label text="Départ:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <HBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <ComboBox fx:id="cmbAeroportDepart" promptText="Sélectionnez départ"
                          styleClass="combo-box-custom"/>
                <DatePicker fx:id="dpDateDepart" promptText="JJ/MM/AAAA"
                            styleClass="date-picker-custom"/>
                <TextField fx:id="txtHeureDepart" promptText="HH:MM"
                           styleClass="text-field-custom"/>
            </HBox>

            <Label text="Arrivée:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <HBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="5">
                <ComboBox fx:id="cmbAeroportArrivee" promptText="Sélectionnez arrivée"
                          styleClass="combo-box-custom"/>
                <DatePicker fx:id="dpDateArrivee" promptText="JJ/MM/AAAA"
                            styleClass="date-picker-custom"/>
                <TextField fx:id="txtHeureArrivee" promptText="HH:MM"
                           styleClass="text-field-custom"/>
                <Button text="🤖 Suggérer"
                        onAction="#suggérerHoraire"
                        styleClass="btn-suggest"/>
            </HBox>

            <Label text="N° Vol:" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <TextField fx:id="txtNumVol" promptText="Ex: AF123"
                       styleClass="text-field-custom" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <HBox spacing="65" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Pays Destination:" styleClass="form-label"/>
                <Label text="Statut:" styleClass="form-label"/>
            </HBox>

            <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <TextField fx:id="txtPaysDestination" promptText="Pays d'arrivée "
                           styleClass="text-field-custom"/>
                <ComboBox fx:id="cmbStatut" promptText="Statut du vol"
                          styleClass="combo-box-custom"/>
            </HBox>

            <Label text="Prix de Base:" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            <TextField fx:id="txtPrixBase" promptText="Prix en €"
                       styleClass="text-field-custom"
                       GridPane.columnIndex="1" GridPane.rowIndex="5"
                       onKeyReleased="#calculerPrixTotal"/>

            <Label text="Places Dispo:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <Spinner fx:id="spinPlaces" min="1" max="500" initialValue="150" editable="true"
                     styleClass="spinner-custom" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

            <Label fx:id="lblChampSpecifique1" text="N° Autorisation Inter.:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <TextField fx:id="txtChampSpecifique1" promptText="Numéro d'autorisation "
                       styleClass="text-field-custom" GridPane.columnIndex="2" GridPane.rowIndex="3"/>

            <Label fx:id="lblChampSpecifique2" text="Exigence Visa:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
            <CheckBox fx:id="chkExigenceVisa" text="Visa requis"
                      styleClass="checkbox-custom" GridPane.columnIndex="2" GridPane.rowIndex="5" onAction="#calculerPrixTotal"/>

            <Label fx:id="lblTerminal" text="Terminal Domestique:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
            <TextField fx:id="txtTerminal" promptText="Nom du terminal domestique"
                       styleClass="text-field-custom"
                       GridPane.columnIndex="2" GridPane.rowIndex="5"/>
        </GridPane>

        <HBox alignment="CENTER" spacing="15" styleClass="box-total-price-large">
            <VBox alignment="CENTER" spacing="2">
                <Label text="💰 Prix Total (avec taxes)" styleClass="text-price-title"/>
                <Label fx:id="lblPrixTotal" text="0.00 €" styleClass="text-price-large"/>
            </VBox>
            <Separator orientation="VERTICAL"/>
            <VBox alignment="CENTER" spacing="2">
                <Label text="📊 Détails" styleClass="text-price-details"/>
                <Label fx:id="lblDetailsPrix" text="Base: 0€ | Taxes: 0€" styleClass="text-price-sub-details"/>
            </VBox>
        </HBox>

        <HBox spacing="8" alignment="CENTER">
            <Button fx:id="btnAjouter" text="➕ Ajouter Vol"
                    onAction="#ajouterVol"
                    styleClass="btn-primary"/>
            <Button fx:id="btnAnnuler" text="❌ Annuler"
                    onAction="#annulerAction"
                    styleClass="btn-secondary"/>
        </HBox>
    </VBox>

    <VBox spacing="6" styleClass="card-container" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="📋 Liste des Vols" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNombreVols" text="Total: 0" styleClass="counter-badge"/>
        </HBox>
        <Separator styleClass="blue-separator"/>

        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="🔍" style="-fx-font-size: 14px;"/>
            <TextField fx:id="txtRecherche"
                       promptText="Rechercher vol..."
                       styleClass="search-field"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <TableView fx:id="tableVols" styleClass="table-view-custom" VBox.vgrow="ALWAYS">
            <columns>
            <TableColumn fx:id="colNumVol" text="N° Vol" prefWidth="80" styleClass="column-header-center"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="90" styleClass="column-header-center"/>
            <TableColumn fx:id="colDepart" text="Départ" prefWidth="120"/>
            <TableColumn fx:id="colArrivee" text="Arrivée" prefWidth="120"/>
            <TableColumn fx:id="colDateDepart" text="Date Départ" prefWidth="90" styleClass="column-header-center"/>
            <TableColumn fx:id="colHeureDepart" text="Heure" prefWidth="70" styleClass="column-header-center"/>
            <TableColumn fx:id="colPlaces" text="Places" prefWidth="60" styleClass="column-header-center"/>
            <TableColumn fx:id="colPrix" text="Prix Total" prefWidth="90" styleClass="column-header-center"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" styleClass="column-header-center"/>
            <TableColumn fx:id="colNumAutorisation" text="N° Autorisation" prefWidth="120" styleClass="column-header-center"/>
            <TableColumn fx:id="colVisa" text="Frais Visa" prefWidth="90" styleClass="column-header-center"/>
            <TableColumn fx:id="colTerminal" text="Terminal" prefWidth="100" styleClass="column-header-center"/>
        </columns>
        <placeholder>
            <VBox spacing="1" alignment="CENTER">
                <Label text="✈" style="-fx-font-size: 38px; -fx-text-fill: #93c5fd;"/>
                <Label text="Aucun vol enregistré"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
            </VBox>
        </placeholder>
    </TableView>
</VBox>
        </VBox>
        </center>

<bottom>
<HBox alignment="CENTER" spacing="10" styleClass="footer-bar">
    <Button fx:id="btnSupprimer" text="🗑 Supprimer"
            onAction="#supprimerVol"
            styleClass="btn-danger"/>
    <Button fx:id="btnModifier" text="✏ Modifier"
            onAction="#modifierVol"
            styleClass="btn-modify"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button text="Quitter"
            onAction="#quitter"
            styleClass="btn-secondary"/>
</HBox>
</bottom>
        </BorderPane>
