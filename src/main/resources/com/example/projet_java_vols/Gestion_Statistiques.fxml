<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.projet_java_vols.Gestion_des_vols.Controller.GestionStatsController"
            prefWidth="1200" prefHeight="700"
            stylesheets="@style.css">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="header-container">
                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 15 0 0;">
                    <Label text="✈ " styleClass="logo-icon"/>
                    <Label text="AeroManager" styleClass="logo-text"/>
                </HBox>

                <Separator orientation="VERTICAL" styleClass="separator-vertical">
                    <HBox.margin>
                        <Insets left="10" right="15"/>
                    </HBox.margin>
                </Separator>
                <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Button fx:id="btnMenuEmployes" text="👥 Employés"
                            onAction="#allerEmploye"
                            styleClass="menu-btn"/>
                    <Button fx:id="btnMenuAeroports" text="🏢 Aéroports"
                            onAction="#allerAeroports"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                    <Button fx:id="btnMenuVols" text="✈ Vols"
                            onAction="#allerVols"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                    <Button fx:id="btnMenuEscales" text="🛬 Escales"
                            onAction="#allerEscales"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                    <Button fx:id="btnMenuReservations" text="🎫 Réservations"
                            onAction="#allerReservations"
                            onMouseEntered="#handleMouseEntered" onMouseExited="#handleMouseExited"
                            styleClass="menu-btn"/>
                    <Button fx:id="btnMenuStats" text="📈 Statistiques"
                            onAction="#allerStats"
                            styleClass="menu-btn-active"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">


                    <Separator orientation="VERTICAL" styleClass="separator-vertical">

                    </Separator>

                    <Button text="👤 Déconnexion"
                            onAction="#deconnexion"
                            styleClass="admin-badge"
                            style="-fx-cursor: hand; -fx-border-color: transparent; -fx-background-color: #eff6ff; -fx-text-fill: #1e40af;"/>

                </HBox>
            </HBox>

            <HBox alignment="CENTER" spacing="8" styleClass="sub-header">
                <Label text="📈" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                <Label text="Dashboard Statistiques des Vols" styleClass="sub-header-title"/>
                <Label text="•" style="-fx-text-fill: #93c5fd; -fx-font-size: 14px;"/>
                <Label text="Vue globale des vols, taux d’occupation et revenus"
                       style="-fx-text-fill: #bfdbfe; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
    <VBox spacing="8" styleClass="content-area">

        <HBox spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="stat-card">
                <Label text="✈" styleClass="icon-blue"/>
                <VBox spacing="2">
                    <Label text="Vols du jour" styleClass="kpi-title"/>
                    <Label fx:id="lblVolsJour" text="0" styleClass="value-blue"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="stat-card">
                <Label text="✈" styleClass="icon-green"/>
                <VBox spacing="2">
                    <Label text="Taux d’occupation moyen" styleClass="title-green"/>
                    <Label fx:id="lblTauxOccupation" text="0 %" styleClass="value-green"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="stat-card">
                <Label text="💶" styleClass="icon-purple"/>
                <VBox spacing="2">
                    <Label text="Revenus du jour" styleClass="title-purple"/>
                    <Label fx:id="lblRevenusJour" text="0.00 €" styleClass="value-purple"/>
                </VBox>
            </HBox>
        </HBox>

        <HBox spacing="8" VBox.vgrow="ALWAYS">
            <VBox spacing="4" VBox.vgrow="ALWAYS" styleClass="chart-container">
                <Label text="Vols par destination (aujourd’hui)" styleClass="chart-title"/>
                <BarChart fx:id="barVolsDestination" VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis label="Destination"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Nombre de vols"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <VBox spacing="4" VBox.vgrow="ALWAYS" styleClass="chart-container">
                <Label text="Répartition vols National / International" styleClass="chart-title"/>
                <PieChart fx:id="pieTypeVol" VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>

        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Label fx:id="lblDerniereMaj" text="Dernière mise à jour: -" styleClass="refresh-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Rafraîchir maintenant"
                    onAction="#relancerRefresh"
                    styleClass="btn-refresh"/>
            <Button text="Quitter"
                    onAction="#quitter"
                    styleClass="btn-secondary"/>
        </HBox>

    </VBox>
</center>

        </BorderPane>
